# =====================================================================
# Variables de entorno (copiar a .env y ajustar).
# Sobrescriben valores de config.yaml. Prefijo: PERMITS_
# Anidación con doble guion bajo: PERMITS_PATHS__EXCEL_FILE
# =====================================================================

# Entorno de ejecución
PERMITS_APP__ENVIRONMENT=local

# Rutas (descomentar para sobrescribir config.yaml)
# PERMITS_PATHS__EXCEL_FILE=data/permisos.xlsx
# PERMITS_PATHS__OUTPUT_DIR=sample_data/expected_output

# Motor de PDF: fpdf2 (portable) | weasyprint (requiere GTK)
# PERMITS_PDF__RENDERER=fpdf2

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
# PERMITS_LOGGING__LEVEL=INFO
